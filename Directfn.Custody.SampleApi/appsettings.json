{
  "Application": {
    "Name": "directfn-custody-sample-api"
  },
  "ConnectionStrings": {
    "CustodyDb": "User Id=custody_user;Password=your_password;Data Source=localhost:1521/ORCLPDB1;"
  },
  "Swagger": {
    "Title": "Directfn Custody Sample API",
    "Version": "v1",
    "Description": "Sample API for Directfn Custody API Framework"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "Enabled": true,
    "Issuer": "Directfn.Custody.Auth",
    "Audience": "Directfn.Custody.Api",
    "AccessTokenMinutes": 10,
    "RefreshTokenHours": 12,
    "UseSecureCookies": false,
    "AccessTokenCookieName": "__Host-dfn-access",
    "RefreshTokenCookieName": "__Host-dfn-refresh",
    "FingerprintCookieName": "dfn-fp",
    "SigningKey": "DEV_ONLY_CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS",
    "SigningCertificate": {
      "StoreName": "",
      "StoreLocation": "",
      "Thumbprint": ""
    }
  },
  "AllowedHosts": "*"
}